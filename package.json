{
  "name": "cat-studio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "mcp": "tsx server/mcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "validate:skills": "powershell -ExecutionPolicy Bypass -File scripts/validate-project-skills.ps1",
    "audit:release": "powershell -ExecutionPolicy Bypass -File scripts/release-audit.ps1",
    "sync:seedance": "powershell -ExecutionPolicy Bypass -File scripts/sync-seedance-skill.ps1",
    "backup": "powershell -ExecutionPolicy Bypass -File scripts/backup.ps1"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "clsx": "^2.1.1",
    "fastify": "^5.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
